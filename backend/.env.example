PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/portalpulse
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_FROM=PortalPulse Pro <your-email@example.com>

RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
PRO_PLAN_AMOUNT=19900

FREE_APPLICATION_LIMIT=10
FREE_ALERT_LIMIT=3
ENABLE_CRON=true
ENABLE_DEMO_MODE=true
ADMIN_EMAIL=admin@portalpulse.pro
DEMO_USER_EMAIL=demo@portalpulse.pro
DEMO_USER_PASSWORD=Demo123!
DEMO_ADMIN_EMAIL=admin@portalpulse.pro
DEMO_ADMIN_PASSWORD=Admin123!
