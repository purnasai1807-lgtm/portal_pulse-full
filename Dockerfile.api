FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

COPY backend/requirements.txt ./requirements.txt
RUN pip install -r requirements.txt
RUN mkdir -p /data

COPY backend/ ./

CMD ["sh", "-lc", "python worker.py & gunicorn app:app --bind 0.0.0.0:${PORT:-8080}"]
